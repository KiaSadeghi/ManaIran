<!DOCTYPE html>
<html lang="<%= lang === 'fa' ? 'fa' : lang %>" dir="<%= lang === 'fa' ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="<%= lang === 'fa' ? 'rtl' : 'ltr' %>" data-lang="<%= lang %>">
  <header class="site-header">
    <div class="container header-grid">
      <div class="header-left">
        <div class="lang-switch">
          <a href="?lang=de">DE</a>
          <a href="?lang=en">EN</a>
          <a href="?lang=fa">FA</a>
        </div>
      </div>

      <div class="header-center">
        <h1 class="logo"><%= t.brand %></h1>

        <nav class="navbar">
          <a href="/?lang=<%= lang %>"><%= t.nav.home %></a>
          <a href="/about?lang=<%= lang %>"><%= t.nav.about %></a>
          <a href="/events?lang=<%= lang %>"><%= t.nav.events %></a>
          <a href="/contact?lang=<%= lang %>"><%= t.nav.contact %></a>
        </nav>
      </div>

      <div class="header-right">
        <div class="date-box">
          <div class="date-line" id="gregorian-date"></div>
          <div class="date-line" id="imperial-date"></div>
        </div>
      </div>
    </div>
  </header>

  <main class="container">