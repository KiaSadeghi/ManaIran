<%- include("partials/header") %>

<section class="hero">
  <div class="hero-content">
    <p class="hero-kicker"><%= t.home.heroKicker %></p>
    <h2><%= t.home.heroTitle %></h2>
    <p class="hero-text"><%= t.home.heroText %></p>

    <div class="hero-buttons">
      <a class="btn btn-primary" href="/about?lang=<%= lang %>"><%= t.home.aboutBtn %></a>
      <a class="btn btn-secondary" href="/events?lang=<%= lang %>"><%= t.home.eventsBtn %></a>
    </div>
  </div>
</section>

<%- include("partials/footer") %>