<%- include("partials/header") %>

<section class="page-section">
  <h2><%= t.about.title %></h2>
  <p><%= t.about.intro %></p>
</section>

<section class="team-section">
  <h3><%= t.about.teamTitle %></h3>

  <div class="team-grid">
    <% teamMembers.forEach(member => { %>
      <div class="team-card">
        <h4><%= member.name %></h4>
        <p><%= member.role %></p>
      </div>
    <% }) %>
  </div>
</section>

<%- include("partials/footer") %>